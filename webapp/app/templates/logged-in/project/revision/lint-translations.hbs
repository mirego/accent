<LintOptions
  @documents={{this.model.documents.entries}}
  @document={{this.documentFilter}}
  @version={{this.versionFilter}}
  @versions={{this.model.versions.entries}}
  @query={{this.query}}
  @onChangeDocument={{fn (mut this.documentFilter)}}
  @onChangeVersion={{fn (mut this.versionFilter)}}
  @onChangeQuery={{fn (mut this.query)}}
/>
{{#if this.showSkeleton}}
  <SkeletonUi::ConflictsItems />
{{else}}
  {{#if this.model.loading}}
    <SkeletonUi::ProgressLine />
  {{/if}}

  <LintTranslationsPage
    @project={{this.model.project}}
    @lintTranslations={{this.model.lintTranslations}}
    @lintChecks={{this.model.lintChecks}}
    @permissions={{this.permissions}}
    @checkFilter={{this.checkFilter}}
    @revisionId={{this.revisionId}}
    @query={{this.query}}
    @onChangeCheckFilter={{this.changeCheckFilter}}
  />
{{/if}}